LIBRARY IEEE;

LIBRARY LPM;
 
USE IEEE.STD_LOGIC_1164.ALL;

USE IEEE.NUMERIC_STD.ALL;

USE LPM.LPM_COMPONENTS.ALL;
 
ENTITY gcd IS

    PORT ( 

        CLOCK   : IN    STD_LOGIC;

        RESETN  : IN    STD_LOGIC;
 
        IO_ADDR : IN    STD_LOGIC_VECTOR(10 DOWNTO 0);

        IO_DATA : INOUT STD_LOGIC_VECTOR(15 DOWNTO 0);

        IO_WRITE: IN    STD_LOGIC;

        IO_READ : IN    STD_LOGIC

    );

END gcd;