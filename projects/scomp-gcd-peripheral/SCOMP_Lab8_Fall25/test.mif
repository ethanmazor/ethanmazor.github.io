WIDTH=16;
DEPTH=2048;

ADDRESS_RADIX=HEX;
DATA_RADIX=HEX;

CONTENT BEGIN
0000: 18FF; -- LOADI &amp;hFF
0001: 9805; -- OUT Hex0
0002: 5008; -- SHIFT 8 ; AC = 0xFF00
0003: 30FF; -- ADDI &amp;hFF ; AC = 0xFFFF
0004: 9804; -- OUT Hex1
0005: 9000; -- IN Switches
0006: 9801; -- OUT LEDs
0007: 7805; -- JNZ WAIT_FOR_SWITCHES_TO_BE_ZERO1
0008: 9000; -- IN Switches
0009: 9801; -- OUT LEDs
000A: 3920; -- AND READY_INPUT_BIT
000B: 7008; -- JZERO WAIT_FOR_FIRST_INPUT
000C: 9000; -- IN Switches
000D: 3921; -- AND MASK_LOWER_8 ; remove ready bit
000E: 9891; -- OUT INPUT1 ; write to INPUT_1
000F: 9091; -- IN INPUT1
0010: 9805; -- OUT Hex0
0011: 1800; -- LOADI 0
0012: 9804; -- OUT Hex1
0013: 9000; -- IN Switches
0014: 9801; -- OUT LEDs
0015: 7813; -- JNZ WAIT_FOR_SWITCHES_TO_BE_ZERO2
0016: 9000; -- IN Switches
0017: 9801; -- OUT LEDs
0018: 3920; -- AND READY_INPUT_BIT
0019: 7016; -- JZERO WAIT_FOR_SECOND_INPUT
001A: 9000; -- IN Switches
001B: 3921; -- AND MASK_LOWER_8 ; remove ready bit
001C: 9892; -- OUT INPUT2 ; write to INPUT_2
001D: 9092; -- IN INPUT2
001E: 5008; -- SHIFT 8
001F: 9804; -- OUT Hex1
0020: 9000; -- IN Switches
0021: 9801; -- OUT LEDs
0022: 7820; -- JNZ WAIT_FOR_SWITCHES_TO_BE_ZERO3
0023: 9000; -- IN Switches
0024: 9801; -- OUT LEDs
0025: 3920; -- AND READY_INPUT_BIT
0026: 7023; -- JZERO WAIT_FOR_MODE
0027: 9000; -- IN Switches
0028: 9890; -- OUT MODE ; write to MODE
0029: 9092; -- IN INPUT2
002A: 5008; -- SHIFT 8
002B: 1125; -- STORE TEMP
002C: 9090; -- IN MODE
002D: 4125; -- OR TEMP
002E: 9804; -- OUT Hex1
002F: 9000; -- IN Switches
0030: 9801; -- OUT LEDs
0031: 782F; -- JNZ WAIT_FOR_SWITCHES_TO_BE_ZERO4
0032: 9000; -- IN Switches
0033: 9801; -- OUT LEDs
0034: 3924; -- AND LSB_MASK
0035: 7032; -- JZERO WAIT_FOR_START
0036: 9000; -- IN Switches
0037: 3920; -- AND READY_INPUT_BIT
0038: 7032; -- JZERO WAIT_FOR_START
0039: 9000; -- IN Switches
003A: 9893; -- OUT Start
003B: 1800; -- LOADI 0
003C: 9805; -- OUT Hex0
003D: 9094; -- IN OUTPUT
003E: 9804; -- OUT Hex1
003F: 9000; -- IN Switches
0040: 3923; -- AND RESET_ROUND
0041: 7843; -- JNZ END_ROUND
0042: 583B; -- JUMP BEGIN_ROUND
0043: 5800; -- JUMP GENERAL_LOOP
[0044..011F] : 0000; -- [empty memory]
0120: 0200; -- READY_INPUT_BIT: DW     &amp;B1000000000
0121: 01FF; -- MASK_LOWER_8: DW        &amp;B0111111111
0122: 0201; -- START_READY: DW         &amp;B1000000001
0123: 0100; -- RESET_ROUND: DW         &amp;B0100000000
0124: 0001; -- LSB_MASK: DW 1
0125: 0000; -- TEMP: DW 0
[0126..07FF] : 0000; -- [empty memory]
END;